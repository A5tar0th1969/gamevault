{
  "name": "gamevault",
  "version": "1.0.0",
  "description": "Cross-platform Gaming UI Launcher — Steam & Epic Games Store integration with fullscreen Aniki UI mode",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:start": "electron .",
    "start:linux": "./start.sh",
    "start:web": "vite preview --host 0.0.0.0 --port 3000"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.gamevault.launcher",
    "productName": "GameVault",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "snap",
        "freebsd"
      ],
      "category": "Game",
      "icon": "public/icon.png",
      "synopsis": "Unified gaming launcher",
      "description": "A cross-platform gaming UI launcher inspired by Playnite and Steam Big Picture. Integrates Steam and Epic Games Store with fullscreen game mode.",
      "executableArgs": [],
      "publish": null
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "public/icon.png"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "public/icon.png",
      "category": "public.app-category.games"
    }
  }
}
